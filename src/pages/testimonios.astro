---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getTestimonios } from '../lib/wordpress.js';

type Testimonio = {
  title?: { rendered?: string };
  content?: { rendered?: string };
  acf?: { cargo?: string };
  _embedded?: {
    'wp:featuredmedia'?: Array<{ source_url?: string }>;
  };
};

const testimonios = (await getTestimonios()) as Testimonio[];
const testimoniosCount = testimonios.length;
const hasTestimonials = testimoniosCount > 0;
const ITEMS_PER_SLIDE = 6;
const groupTestimonials = (items: Testimonio[], size = ITEMS_PER_SLIDE) => {
  const groups: Testimonio[][] = [];
  for (let i = 0; i < items.length; i += size) {
    groups.push(items.slice(i, i + size));
  }
  return groups;
};
const paginatedTestimonials = groupTestimonials(testimonios, ITEMS_PER_SLIDE);

const rawBase = import.meta.env.BASE_URL ?? '/';
const normalizedBase = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const basePathForLinks = normalizedBase === '/' ? '' : normalizedBase.replace(/\/$/, '');
const homeLink = normalizedBase === '/' ? '/' : normalizedBase;
const anchorLink = (hash: string) => {
  const cleanHash = hash.startsWith('#') ? hash.slice(1) : hash;
  return `${basePathForLinks || ''}/#${cleanHash}`;
};
const contactLink = anchorLink('#contacto');
const canonicalUrl = 'https://ckdelap.cl/testimonios';
---

<Layout
  title="Testimonios de pacientes - Psicóloga Camila Kush de la Puente"
  description="Lee testimonios reales de pacientes adultos que realizaron procesos de psicoterapia online con Camila Kush de la Puente. Historias de transformación, contención profesional y sanación emocional."
  canonical={canonicalUrl}
>
  <Header useAbsoluteLinks />
  <main class="testimonios-page">
    <section class="testimonios-hero">
      <div class="hero-content">
        <h1>Testimonios de procesos psicoterapeuticos online</h1>
        <p>
          Cada historia refleja el compromiso, la valentía y el acompañamiento profesional en el proceso terapéutico.
          Conoce cómo el trabajo conjunto ha permitido resignificar experiencias, sanar heridas y recuperar la confianza .
        </p>
        <div class="hero-stats">
          <div class="stat-card">
            <span class="stat-value">{testimoniosCount || '20+'}</span>
            <span class="stat-label">Testimonios verificados</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">100%</span>
            <span class="stat-label">Sesiones online</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">+8 años</span>
            <span class="stat-label">de experiencia clínica</span>
          </div>
        </div>
      </div>
    </section>

    <section id="testimonios-lista" class="testimonios-lista">
      <div class="section-header">
        <h2>Lo que dicen quienes han trabajado conmigo</h2>
      </div>

      {hasTestimonials ? (
        <div class="testimonios-carousel" data-groups={paginatedTestimonials.length}>
          <div class="carousel-track">
            {paginatedTestimonials.map((group, groupIndex) => (
              <div class:list={{ 'carousel-slide': true, active: groupIndex === 0 }} data-slide-index={groupIndex}>
                <div class="grid">
                  {group.map((testimonio) => (
                    <article class="testimonio-card">
                      <div class="quote-icon" aria-hidden="true">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                          <path d="M7 7h4v4H9a2 2 0 0 0-2 2v4H3v-4a6 6 0 0 1 6-6z" />
                          <path d="M17 7h4v4h-2a2 2 0 0 0-2 2v4h-4v-4a6 6 0 0 1 6-6z" />
                        </svg>
                      </div>
                      <div class="testimonio-content" set:html={testimonio.content?.rendered || ''} />
                      <div class="autor">
                        {testimonio._embedded?.['wp:featuredmedia']?.[0]?.source_url && (
                          <div class="autor-foto">
                            <img src={testimonio._embedded['wp:featuredmedia'][0].source_url} alt={testimonio.title?.rendered || 'Paciente'} loading="lazy" />
                          </div>
                        )}
                        <div class="autor-info">
                          <h3 set:html={testimonio.title?.rendered || 'Paciente anónimo'} />
                          {testimonio.acf?.cargo && <p>{testimonio.acf.cargo}</p>}
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            ))}
          </div>

          {paginatedTestimonials.length > 1 && (
            <>
              <div class="carousel-controls">
                <button class="carousel-btn" type="button" data-carousel="prev" aria-label="Ver testimonios anteriores">
                  <span>&larr;</span>
                </button>
                <button class="carousel-btn" type="button" data-carousel="next" aria-label="Ver testimonios siguientes">
                  <span>&rarr;</span>
                </button>
              </div>
              <div class="carousel-dots">
                {paginatedTestimonials.map((_, dotIndex) => (
                  <button
                    type="button"
                    class:list={{ 'carousel-dot': true, active: dotIndex === 0 }}
                    data-carousel-dot={dotIndex}
                    aria-label={`Ver grupo ${dotIndex + 1}`}
                  ></button>
                ))}
              </div>
            </>
          )}
        </div>
      ) : (
        <div class="empty-state">
          <h3>Aún no hay testimonios publicados</h3>
          <p>Pronto compartiremos experiencias reales de pacientes que ya han vivido el proceso terapéutico.</p>
        </div>
      )}
    </section>

    <section class="cta-section">
      <div class="cta-card">
        <div>
          <span class="cta-badge">¿Lista para tu proceso?</span>
          <h2>Agenda una primera sesión de exploración</h2>
          <p>Hablemos sobre lo que estás viviendo hoy y cómo puedo acompañarte con estrategias terapéuticas individualizadas.</p>
        </div>
        <div class="cta-actions">
          <a href={homeLink} class="cta-button secondary">Volver al inicio</a>
          <a href={contactLink} class="cta-button">Ir al formulario de contacto</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.querySelector('.testimonios-carousel');
    if (!carousel) return;

    const slides = Array.from(carousel.querySelectorAll('.carousel-slide'));
    if (!slides.length) return;
    const dots = Array.from(carousel.querySelectorAll('[data-carousel-dot]'));
    const prevBtn = carousel.querySelector('[data-carousel="prev"]');
    const nextBtn = carousel.querySelector('[data-carousel="next"]');

    let current = 0;

    const updateSlides = () => {
      slides.forEach((slide, index) => {
        slide.classList.toggle('active', index === current);
      });
      dots.forEach((dot, index) => {
        dot.classList.toggle('active', index === current);
        dot.setAttribute('aria-current', index === current ? 'true' : 'false');
      });
    };

    const goTo = (index) => {
      const total = slides.length;
      current = (index + total) % total;
      updateSlides();
    };

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => goTo(index));
    });

    updateSlides();
  });
</script>

<style>
  .testimonios-page {
    background: linear-gradient(180deg, #f6f5f1 0%, #ffffff 60%, #f4fbfc 100%);
    padding-top: 140px;
  }

  .testimonios-hero {
    padding: 3rem clamp(1.5rem, 4vw, 4rem);
  }

  .hero-content h1 {
    font-size: clamp(2.2rem, 3.8vw, 3.75rem);
    line-height: 1.15;
    color: #1c2230;
    margin: 1rem 0 1.25rem;
    font-family: 'Playfair Display', serif;
  }

  .hero-content p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #4a5768;
    max-width: 720px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.5rem;
    border-radius: 999px;
    background: rgba(255, 148, 132, 0.15);
    color: #ff6f61;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.85rem;
  }

  .hero-badge::after {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: currentColor;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .stat-card {
    background: white;
    border-radius: 20px;
    padding: 1.5rem;
    box-shadow: 0 25px 45px rgba(14, 30, 37, 0.08);
    border: 1px solid rgba(15, 23, 42, 0.05);
  }

  .stat-value {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: #1f2937;
  }

  .stat-label {
    color: #6b7280;
    font-size: 0.95rem;
  }

  @media (min-width: 900px) {
    .testimonios-hero {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-content {
      max-width: 760px;
      margin: 0 auto;
      text-align: center;
    }

    .hero-stats {
      margin-left: auto;
      margin-right: auto;
    }
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 0 1rem;
  }

  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    background: rgba(86, 186, 192, 0.15);
    color: #276e74;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.8rem;
  }

  .section-header h2 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    color: #1b2430;
    margin: 1rem 0 0.7rem;
  }

  .section-header p {
    color: #556071;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .testimonios-lista {
    padding: 2rem clamp(1.5rem, 4vw, 4rem) 4rem;
  }

  .testimonios-carousel {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
  }

  .carousel-track {
    position: relative;
  }

  .carousel-slide {
    display: none;
    animation: fadeSlide 0.4s ease;
  }

  .carousel-slide.active {
    display: block;
  }

  .grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.75rem;
    margin: 0 auto;
  }

  .grid .testimonio-card {
    flex: 1 1 calc(33.333% - 1.75rem);
    min-width: 300px;
    max-width: 420px;
  }

  @media (max-width: 1024px) {
    .grid .testimonio-card {
      flex: 1 1 calc(50% - 1.75rem);
    }
  }

  @media (max-width: 640px) {
    .grid .testimonio-card {
      flex: 1 1 100%;
    }
  }

  .carousel-controls {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .carousel-btn {
    background: #ffffff;
    border: 1px solid rgba(31, 41, 55, 0.1);
    border-radius: 999px;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1.25rem;
    color: #1f2937;
    box-shadow: 0 15px 35px rgba(15, 23, 42, 0.12);
    transition: transform 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
  }

  .carousel-btn:hover {
    transform: translateY(-2px);
    color: #56BAC0;
    box-shadow: 0 18px 40px rgba(86, 186, 192, 0.25);
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #d1d5db;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .carousel-dot.active {
    background: #56BAC0;
    transform: scale(1.15);
  }

  @keyframes fadeSlide {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .testimonio-card {
    background: white;
    border-radius: 28px;
    padding: 2rem;
    border: 1px solid rgba(17, 24, 39, 0.05);
    box-shadow: 0 20px 45px rgba(12, 22, 40, 0.08);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
  }

  .testimonio-card::after {
    content: '';
    position: absolute;
    inset: 1px;
    border-radius: 25px;
    border: 1px dashed rgba(86, 186, 192, 0.25);
    pointer-events: none;
  }

  .quote-icon {
    width: 54px;
    height: 54px;
    border-radius: 16px;
    background: linear-gradient(135deg, #56BAC0, #3FA1A8);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 30px rgba(86, 186, 192, 0.35);
  }

  .testimonio-content :global(p) {
    margin: 0;
    color: #1f2937;
    line-height: 1.85;
    font-size: 1rem;
  }

  .testimonio-content :global(p + p) {
    margin-top: 0.85rem;
    color: #4b5563;
  }

  .autor {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .autor-foto {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    overflow: hidden;
    border: 3px solid rgba(255, 148, 132, 0.35);
  }

  .autor-info h3 {
    margin: 0;
    font-size: 1.05rem;
    color: #111827;
  }

  .autor-info p {
    margin: 0.15rem 0 0;
    color: #6b7280;
    font-size: 0.95rem;
  }

  .empty-state {
    text-align: center;
    background: white;
    padding: 3rem;
    border-radius: 32px;
    border: 1px solid rgba(15, 23, 42, 0.05);
    box-shadow: 0 30px 60px rgba(15, 23, 42, 0.08);
  }

  .cta-section {
    padding: 1rem clamp(1.5rem, 4vw, 4rem) 4rem;
  }

  .cta-card {
    background: linear-gradient(135deg, #111826, #1f2b46);
    border-radius: 36px;
    padding: clamp(2rem, 4vw, 3.5rem);
    color: white;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
    justify-content: space-between;
  }

  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 1.1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .cta-card h2 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    margin: 1rem 0 0.5rem;
  }

  .cta-card p {
    margin: 0;
    color: rgba(255, 255, 255, 0.8);
    max-width: 580px;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.75rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #56BAC0, #4a9ba1);
    color: white;
    text-decoration: none;
    font-weight: 600;
    box-shadow: 0 20px 35px rgba(86, 186, 192, 0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 25px 45px rgba(86, 186, 192, 0.4);
  }

  .cta-button.secondary {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: none;
  }

  @media (max-width: 1024px) {
    .testimonios-hero {
      grid-template-columns: 1fr;
      padding-top: 1rem;
    }

    .hero-highlight {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }

  @media (max-width: 640px) {
    .hero-stats {
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    }

    .cta-card {
      flex-direction: column;
      text-align: center;
    }

    .cta-actions {
      flex-direction: column;
      width: 100%;
    }

    .cta-button,
    .cta-button.secondary {
      width: 100%;
    }
  }
</style>
