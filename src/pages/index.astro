	---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiciosGrid from '../components/ServiciosGrid.astro';
import Testimonios from '../components/Testimonios.astro';
import ContactInfo from '../components/ContactInfo.astro';

const convenios = [
	{ name: 'Colmena', logo: '/images/colmena.png' },
	{ name: 'Banmédica', logo: '/images/banmedica.png' },
	{ name: 'Vida Tres', logo: '/images/vidatres.png' },
	{ name: 'Cruz Blanca', logo: '/images/cruzblanca.png' },
	{ name: 'Consalud', logo: '/images/consalud.png' }
];
---

<Layout title="Psicóloga Clínica - Psicoterapia Adulto">
	<Header />
	
	<section id="inicio" class="hero">
		<div class="hero-slider">
			<div class="slide slide-one active">
				<div class="hero-content">
					<h1>Las heridas del pasado no son tu culpa.<br><span class="highlight">Sanar, hoy, sí es tu responsabilidad.</span></h1>
				</div>
			</div>
			<div class="slide slide-two">
				<div class="hero-content">
					<h1>Iniciar un proceso terapéutico es una decisión valiente.<br>Implica detenerse, mirar hacia dentro y asumir el compromiso de comprender aquello que duele.</h1>
				</div>
			</div>
			<div class="slide slide-three">
				<div class="hero-content">
					<h1>Te ofrezco un espacio terapéutico <span class="highlight">100% online, confidencial y seguro</span>, donde podrás explorar tu historia con respeto y contención profesional.</h1>
				</div>
			</div>
			<div class="slide slide-four">
				<div class="hero-content">
					<h1>Sanar no es olvidar lo vivido;<br>es aprender a resignificarlo para vivir con mayor claridad, equilibrio y sentido.</h1>
				</div>
			</div>
			<div class="slide">
				<div class="hero-content">
					<h1>Si estás aquí, probablemente algo dentro de ti<br><span class="highlight">ya sabe que es momento de hacerlo distinto.</span></h1>
					<div class="cta-group">
						<a href="#contacto" class="cta-button primary">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
							</svg>
							Comienza tu Proceso Terapéutico
						</a>
					</div>
				</div>
			</div>
		</div>
		
		<div class="slider-indicators">
			<button class="indicator active" onclick="goToSlide(0)"></button>
			<button class="indicator" onclick="goToSlide(1)"></button>
			<button class="indicator" onclick="goToSlide(2)"></button>
			<button class="indicator" onclick="goToSlide(3)"></button>
			<button class="indicator" onclick="goToSlide(4)"></button>
		</div>
	</section>

	

	<section id="areas-atencion" class="areas-section">
		<div class="container">
			<div class="section-header">
				<span class="section-badge">¿En qué puedo ayudarte?</span>
				<h2>Áreas de atención</h2>
				<p style="font-size: 1.1rem; color:#D96B58">Acompañamiento terapéutico profesional en las áreas que necesitas para tu bienestar emocional</p>
			</div>
			
			<div class="areas-grid">
				<div class="area-card">
					<div class="area-icon">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M9.5 2A2.5 2.5 0 0 1 12 4.5a2.5 2.5 0 0 1-2.5 2.5A2.5 2.5 0 0 1 7 4.5 2.5 2.5 0 0 1 9.5 2z"/>
							<path d="M9.5 7C5.36 7 2 10.36 2 14.5S5.36 22 9.5 22 17 18.64 17 14.5 13.64 7 9.5 7z"/>
							<path d="M15 2a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2 2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
							<path d="M15 8c-2.21 0-4 1.79-4 4v2c0 2.21 1.79 4 4 4s4-1.79 4-4v-2c0-2.21-1.79-4-4-4z"/>
						</svg>
					</div>
					<h3>Salud emocional y estado de ánimo</h3>
					<p>Acompañamiento en procesos de depresión, ansiedad, trastornos del pánico, traumas y trastornos de la personalidad (bipolaridad, TLP).</p>
				</div>
				
				<div class="area-card">
					<div class="area-icon">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/>
							<path d="M12 8v4"/>
							<circle cx="12" cy="16" r="1"/>
						</svg>
					</div>
					<h3>Situaciones de vida difíciles</h3>
					<p>Apoyo en experiencias de abuso sexual, duelo, enfermedades (cáncer, alopecia) y otros momentos que requieren contención profesional.</p>
				</div>
				
				<div class="area-card">
					<div class="area-icon">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
							<circle cx="9" cy="7" r="4"/>
							<path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
							<path d="M16 3.13a4 4 0 0 1 0 7.75"/>
						</svg>
					</div>
					<h3>Relaciones y vínculos</h3>
					<p>Trabajo en conflictos familiares, límites, habilidades de comunicación, celos e inseguridades en la relación de pareja.</p>
				</div>
				
				<div class="area-card">
					<div class="area-icon">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
						</svg>
					</div>
					<h3>Desarrollo personal y laboral</h3>
					<p>Definición de metas concretas, toma de decisiones, fortalecimiento de la perseverancia, apertura de conciencia y desarrollo del potencial.</p>
				</div>
				
				<div class="area-card">
					<div class="area-icon">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
							<polyline points="14,2 14,8 20,8"/>
							<line x1="16" y1="13" x2="8" y2="13"/>
							<line x1="16" y1="17" x2="8" y2="17"/>
							<polyline points="10,9 9,9 8,9"/>
						</svg>
					</div>
					<h3>Manejo del estrés y burnout</h3>
					<p>Estrategias para recuperar el equilibrio cuando el trabajo o las exigencias del día a día te sobrepasan.</p>
				</div>
				
				<div class="area-card">
					<div class="area-icon">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
						</svg>
					</div>
					<h3>Autoestima y regulación emocional</h3>
					<p>Trabajo en autoestima, impulsividad, control de pensamientos intrusivos y hábitos más saludables.</p>
				</div>
				
				<div class="area-card">
					<div class="area-icon">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="10"/>
							<path d="M12 6v6l4 2"/>
						</svg>
					</div>
					<h3>Desapego y soltar</h3>
					<p>Acompañamiento en el aprendizaje del desapego como herramienta de bienestar y crecimiento personal.</p>
				</div>
				
				<div class="area-card">
					<div class="area-icon">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2L2 7l10 5 10-5-10-5z"/>
							<path d="M2 17l10 5 10-5"/>
							<path d="M2 12l10 5 10-5"/>
						</svg>
					</div>
					<h3>Sexualidad y bienestar</h3>
					<p>Abordaje de problemáticas sexuales desde una mirada psicológica, sin juicios y con total confidencialidad.</p>
				</div>
			</div>
		</div>
	</section>

	<div id="servicios">
		<ServiciosGrid />
	</div>

	<section id="temas" class="temas-section">
		<div class="container">
			<div class="section-header">
				<span class="section-badge">Temas Abordados</span>
				<h2>Especialista en Diversas Áreas de la Salud Mental</h2>
				<p class="section-subtitle">Acompañamiento terapéutico integral para tu bienestar</p>
			</div>

			<div class="temas-categories">
				<div class="categoria-card">
					<div class="categoria-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M9 11l3 3L22 4"/>
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
						</svg>
					</div>
					<h3>Trastornos del Estado de Ánimo</h3>
					<ul>
						<li>Depresión</li>
						<li>Ansiedad</li>
						<li>Trastornos de Pánico</li>
						<li>Manejo de Traumas</li>
					</ul>
				</div>

				<div class="categoria-card">
					<div class="categoria-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/>
						</svg>
					</div>
					<h3>Trastornos de la Personalidad</h3>
					<ul>
						<li>Bipolaridad</li>
						<li>Trastorno Límite de la Personalidad</li>
						<li>Manejo de impulsividad</li>
						<li>Control de pensamientos intrusivos</li>
					</ul>
				</div>

				<div class="categoria-card">
					<div class="categoria-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
							<circle cx="8.5" cy="7" r="4"/>
							<line x1="20" y1="8" x2="20" y2="14"/>
							<line x1="23" y1="11" x2="17" y2="11"/>
						</svg>
					</div>
					<h3>Relaciones y Familia</h3>
					<ul>
						<li>Establecimiento de límites</li>
						<li>Conflictos familiares</li>
						<li>Habilidades sociales y comunicación</li>
						<li>Celos e inseguridades de pareja</li>
					</ul>
				</div>

				<div class="categoria-card">
					<div class="categoria-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="10"/>
							<polyline points="12 6 12 12 16 14"/>
						</svg>
					</div>
					<h3>Desarrollo Personal y Laboral</h3>
					<ul>
						<li>Metas laborales concretas</li>
						<li>Objetivos personales</li>
						<li>Fortalecimiento de perseverancia</li>
						<li>Toma de decisiones</li>
					</ul>
				</div>

				<div class="categoria-card">
					<div class="categoria-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
						</svg>
					</div>
					<h3>Manejo del Estrés y Bienestar</h3>
					<ul>
						<li>Burnout laboral</li>
						<li>Problemas sexuales</li>
						<li>Autoestima</li>
						<li>Hábitos saludables</li>
					</ul>
				</div>

				<div class="categoria-card">
					<div class="categoria-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<heart/>
						</svg>
					</div>
					<h3>Apoyo y Crecimiento</h3>
					<ul>
						<li>Abuso sexual</li>
						<li>Acompañamiento en tratamientos médicos</li>
						<li>Práctica del desapego</li>
						<li>Apertura de conciencia</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section id="casos" class="casos-section">
		<div class="container">
			<div class="section-header">
				<h2>Situaciones Comunes que Abordamos</h2>
				<p class="section-subtitle">Te acompaño en tu proceso de sanación y crecimiento</p>
			</div>

			<div class="casos-grid">
				<div class="caso-card">
					<div class="caso-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M9 11l3 3L22 4"/>
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
						</svg>
					</div>
					<p>Siento que no puedo controlar mi ansiedad y los pensamientos negativos</p>
				</div>

				<div class="caso-card">
					<div class="caso-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="10"/>
							<path d="M16 8s-1.5 2-4 2 4-4 4-4"/>
							<path d="M8 16s1.5-2 4-2-4 4-4 4"/>
						</svg>
					</div>
					<p>Estoy pasando por una depresión y no encuentro motivación para nada</p>
				</div>

				<div class="caso-card">
					<div class="caso-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/>
						</svg>
					</div>
					<p>Necesito ayuda para sanar traumas del pasado que me afectan hoy</p>
				</div>

				<div class="caso-card">
					<div class="caso-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
							<circle cx="8.5" cy="7" r="4"/>
							<line x1="20" y1="8" x2="20" y2="14"/>
							<line x1="23" y1="11" x2="17" y2="11"/>
						</svg>
					</div>
					<p>Tengo problemas en mis relaciones y no sé cómo establecer límites</p>
				</div>

				<div class="caso-card">
					<div class="caso-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="10"/>
							<polyline points="12 6 12 12 16 14"/>
						</svg>
					</div>
