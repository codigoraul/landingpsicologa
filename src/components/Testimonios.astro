---
import { getTestimonios } from '../lib/wordpress.js';

type Testimonio = {
  title: { rendered: string };
  content: { rendered: string };
  acf?: { cargo?: string };
  _embedded?: {
    'wp:featuredmedia'?: Array<{ source_url: string }>;
  };
};

const allTestimonios = await getTestimonios();
const testimonios = (allTestimonios || []) as Testimonio[];
const testimoniosPages = testimonios.reduce((pages: Testimonio[][], item: Testimonio, index: number) => {
  if (index % 3 === 0) pages.push([]);
  pages[pages.length - 1].push(item);
  return pages;
}, [] as Testimonio[][]);
---

<section class="testimonios-section">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Experiencias reales</span>
      <h2>Testimonios que inspiran confianza</h2>
      <p class="section-subtitle">Historias de transformación y acompañamiento terapéutico</p>
    </div>
    
    <div class="testimonios-carousel" data-testimonios-carousel>
      <button class="carousel-control prev" type="button" aria-label="Testimonio anterior">‹</button>
      <div class="testimonios-viewport">
        <div class="testimonios-track" data-track>
          {testimoniosPages && testimoniosPages.length > 0 ? (
            testimoniosPages.map((group: Testimonio[], pageIndex: number) => (
              <div class="testimonios-page" style={`animation-delay: ${pageIndex * 0.15}s`}>
                {group.map((testimonio, index) => (
                  <article class="testimonio-card" style={`animation-delay: ${(pageIndex * 3 + index) * 0.1}s`}>
                <div class="quote-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M7 7h4v4H9a2 2 0 0 0-2 2v4H3v-4a6 6 0 0 1 6-6z" />
                    <path d="M17 7h4v4h-2a2 2 0 0 0-2 2v4h-4v-4a6 6 0 0 1 6-6z" />
                  </svg>
                </div>
                <div class="rating">
                  {[...Array(5)].map(() => (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  ))}
                </div>
                
                <div class="content" set:html={testimonio.content.rendered} />
                
                <div class="author">
                  {testimonio._embedded?.['wp:featuredmedia']?.[0]?.source_url && (
                    <div class="author-photo">
                      <img 
                        src={testimonio._embedded['wp:featuredmedia'][0].source_url} 
                        alt={testimonio.title.rendered}
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="author-info">
                    <h4 set:html={testimonio.title.rendered} />
                    {testimonio.acf?.cargo && (
                      <p class="cargo">{testimonio.acf.cargo}</p>
                    )}
                  </div>
                </div>
                  </article>
                ))}
              </div>
            ))
          ) : (
            <p class="no-testimonios">No hay testimonios disponibles</p>
          )}
        </div>
      </div>
      <button class="carousel-control next" type="button" aria-label="Siguiente testimonio">›</button>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.querySelector('[data-testimonios-carousel]');
    if (!carousel) return;

    const track = carousel.querySelector('[data-track]');
    const prevBtn = carousel.querySelector('.carousel-control.prev');
    const nextBtn = carousel.querySelector('.carousel-control.next');
    if (!track || !prevBtn || !nextBtn) return;

    let pageIndex = 0;

    const update = () => {
      const pages = Array.from(track.querySelectorAll('.testimonios-page'));
      if (!pages.length) return;
      const totalPages = pages.length;
      pageIndex = Math.min(pageIndex, totalPages - 1);

      track.style.transform = `translateX(-${pageIndex * 100}%)`;

      prevBtn.disabled = pageIndex === 0;
      nextBtn.disabled = pageIndex === totalPages - 1;
    };

    prevBtn.addEventListener('click', () => {
      pageIndex = Math.max(0, pageIndex - 1);
      update();
    });

    nextBtn.addEventListener('click', () => {
      const pages = Array.from(track.querySelectorAll('.testimonios-page'));
      const totalPages = Math.max(1, pages.length);
      pageIndex = Math.min(totalPages - 1, pageIndex + 1);
      update();
    });

    window.addEventListener('resize', update);
    update();
  });
</script>

<style>
  .testimonios-section {
    padding: 6.5rem 2rem;
    background: #f7f4f0;
    position: relative;
    overflow: hidden;
  }
  
  .testimonios-section::before,
  .testimonios-section::after {
    content: '';
    position: absolute;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,148,132,0.25) 0%, rgba(255,148,132,0) 70%);
    filter: blur(8px);
  }
  
  .testimonios-section::before {
    top: -80px;
    left: -60px;
  }
  
  .testimonios-section::after {
    bottom: -120px;
    right: -40px;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 1.5rem;
    border-radius: 999px;
    background: rgba(35, 198, 198, 0.12);
    color: #1f2933;
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  
  .section-badge::after {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #FF9484;
  }
  
  .section-header h2 {
    margin: 1rem auto;
    max-width: 720px;
    font-size: 32px;
    font-weight: 700;
    color: #464D57 !important;
    letter-spacing: -0.01em;
    line-height: 1.25;
    font-family: 'Cormorant Garamond', serif !important;
  }
  
  .section-subtitle {
    color: #6b7280;
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .testimonios-carousel {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .testimonios-viewport {
    overflow: hidden;
    width: 100%;
  }

  .testimonios-track {
    display: flex;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .testimonios-page {
    min-width: 100%;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .carousel-control {
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 999px;
    background: #56BAC0;
    color: #fff;
    font-size: 1.8rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(86, 186, 192, 0.35);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .carousel-control:hover {
    transform: translateY(-2px);
  }

  .carousel-control:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  
  .testimonio-card {
    background: #ffffff;
    padding: 3rem 2.5rem;
    border-radius: 32px;
    border: 1px solid rgba(18, 52, 77, 0.08);
    box-shadow: 0 25px 55px rgba(26, 43, 68, 0.12);
    position: relative;
    overflow: hidden;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    animation: cardFade 0.6s ease forwards;
  }
  
  .testimonio-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(130deg, rgba(255, 255, 255, 0) 15%, rgba(163, 221, 233, 0.28) 100%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  
  .testimonio-card:hover::before {
    opacity: 1;
  }
  
  .testimonio-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 35px 65px rgba(26, 43, 68, 0.18);
  }
  
  .quote-icon {
    width: 60px;
    height: 60px;
    border-radius: 20px;
    background: #56BAC0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.75rem;
    color: white;
    box-shadow: 0 15px 35px rgba(86, 186, 192, 0.35);
  }
  
  .rating {
    display: inline-flex;
    gap: 0.15rem;
    margin-bottom: 1.25rem;
    color: #FFB84C;
  }
  
  .rating svg {
    filter: drop-shadow(0 4px 10px rgba(255, 184, 76, 0.35));
  }
  
  .content :global(p) {
    margin: 0;
    color: #1e1f2b;
    font-size: 1.1rem;
    line-height: 1.9;
    font-weight: 500;
    font-family: 'Raleway', sans-serif;
  }
  
  .content :global(p + p) {
    margin-top: 0.75rem;
    color: #4b5563;
  }
  
  .author {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
  }
  
  .author-photo {
    width: 70px;
    height: 70px;
    border-radius: 24px;
    overflow: hidden;
    border: 3px solid rgba(255, 148, 132, 0.5);
    box-shadow: 0 15px 35px rgba(255, 148, 132, 0.35);
  }
  
  .author-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .testimonios-carousel {
      gap: 0.75rem;
    }

    .testimonios-page {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .testimonio-card {
      padding: 2rem 1.5rem;
      border-radius: 24px;
    }

    .carousel-control {
      width: 38px;
      height: 38px;
      font-size: 1.4rem;
    }
  }
</style>
